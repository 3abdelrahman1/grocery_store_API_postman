				{
					"name": "GET status",
					"event": [
						{
							"listen": "test",
							"script": {
								"id": "00c1515c-3161-4ee4-8888-7ed3afae8e1c",
								"exec": [
									"let response = pm.response.json();\r",
									"\r",
									"pm.test(\"Should return a object\", function () {\r",
									"    pm.expect(response, 'The response is not an object').to.be.an('object');\r",
									"});\r",
									"pm.test(\"Should contain the `status` property in the response\", function () {\r",
									"    pm.expect(response, 'The response does not contain the property').to.haveOwnProperty('status');\r",
									"});\r",
									"\r",
									"pm.test(\"Should return a string for the `status` property\", function () {\r",
									"    pm.expect(response.status, 'The property is not a string').to.be.a('string');\r",
									"});\r",
									"pm.test(\"Should return a string for the `status` property\", function () {\r",
									"    pm.expect(response.status, 'The property is not a string').to.eql('UP');\r",
									"});\r",
									"pm.expect(response).to.have.property('status', 'UP');"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
					"id": "387ba92f-a6c2-405d-8874-592e8764c512",
