				{
					"name": "GET all products",
					"event": [
						{
							"listen": "test",
							"script": {
								"id": "b355354e-afb2-453e-a974-4e6ee14aa061",
								"exec": [
									"let response = pm.response.json();\r",
									"const moment = require('moment');\r",
									"const today = moment().format(\"YYYY-MM-DD\");\r",
									"const responseDate = moment(response.updatedAt).format(\"YYYY-MM-DD\");\r",
									"pm.test(\"successful response.\", function () {\r",
									"    pm.response.to.have.status(200);\r",
									"});\r",
									"\r",
									"pm.test(\"parameters provided are invalid.\", function () {\r",
									"    pm.response.to.not.have.status(400);\r",
									"});\r",
									"\r",
									"pm.test('\"content-type\" is present in response headers', () => {\r",
									"    pm.response.to.have.header('content-type');\r",
									"});\r",
									"\r",
									"pm.test('\"content-type\" response metadata is \"application/json\"', () => {\r",
									"   \r",
									"    // Using pm.expect\r",
									"    pm.expect(pm.response.headers.get('content-type')).to.equal('application/json');\r",
									"  \r",
									"});\r",
									"pm.test(\"Date is today\", function () {\r",
									"    pm.expect(responseDate).to.equal(today);\r",
									"});\r",
									"\r",
									"for (i = 0; i < response.length; i++) {\r",
									"    let ID = pm.response.json()[i].id;\r",
									"    pm.collectionVariables.set(\"id_\" + ID, ID);\r",
									"    \r",
									"}\r",
									"\r",
									"pm.test(\"Response schema is valid\", function () {\r",
									"    const response = pm.response.json();\r",
									"    pm.expect(response).to.be.an('array').that.is.not.empty;\r",
									"\r",
									"    response.forEach(product => {\r",
									"        pm.expect(product).to.have.all.keys('id', 'category', 'name', 'inStock');\r",
									"        pm.expect(product.id).to.be.a('number');\r",
									"        pm.expect(product.category).to.be.a('string');\r",
									"        pm.expect(product.name).to.be.a('string');\r",
									"        pm.expect(product.inStock).to.be.a('boolean');\r",
									"    });\r",
									"});\r",
									""
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
